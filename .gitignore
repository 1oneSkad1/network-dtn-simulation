# --- Python 관련 ---
# 가상환경
venv/
.venv/
env/
bin/
lib/
include/

# 컴파일된 파일
__pycache__/
*.py[cod]
*$py.class

# --- 도커 및 환경 설정 ---
# 환경 변수 (비밀번호, API 키 포함 가능성)
.env

# 도커 로그 및 데이터
docker-compose.override.yml
*.log

# --- 시스템 파일 ---
# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# --- ION-DTN 관련 (빌드 중 생성되는 임시 파일) ---
# 빌드 결과물이나 로그가 프로젝트 내부에 생길 경우 추가
ion.log
*.tmp